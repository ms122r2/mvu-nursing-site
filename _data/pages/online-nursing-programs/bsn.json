    {
      "type": "ContentBlock",
      "props": {
        "id": "content-curriculum",
        "body": "The BSN sequences foundational arts, sciences, and general education (NURS 307 Health Assessment, NURS 309 Pharmacology, NURS 330 Pathophysiology) alongside nursing-specific coursework (NURS 341 Med-Surg, NURS 342 Maternal/Child, NURS 406 Community Health, NURS 416 Leadership). Students complete 120 total credits, with clinical placements integrated throughout the upper-division sequence.",
        "image": "",
        "heading": "<p>Curriculum Overview</p>",
        "imagePosition": "left",
        "backgroundColor": "gray",
        "animationVariant": "fadeUp"
