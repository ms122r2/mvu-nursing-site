            "heading": "100% Online Coursework",
            "description": "Didactic content delivered fully online on your schedule."
          },
          {
            "icon": "📍",
            "heading": "Local Clinical Placements",
            "description": "Complete clinical hours in your own community."
          },
          {
            "icon": "🎓",
            "heading": "Direct-Entry Pathways",
            "description": "Stackable credits into MSN and DNP programs."
          },
          {
            "icon": "✅",
            "heading": "No GRE Required",
            "description": "Application focuses on academics and goals, not test scores."
          },
          {
            "icon": "📅",
            "heading": "Six Starts Per Year",
            "description": "Begin when you're ready — six cohorts annually."
          },
          {
            "icon": "👩‍⚕️",
            "heading": "Practicing Faculty",
            "description": "Every instructor is a practicing clinician."
