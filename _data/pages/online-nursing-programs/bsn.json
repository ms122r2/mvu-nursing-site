    {
      "type": "ContentBlock",
      "props": {
        "id": "content-1",
        "body": "The Institute of Medicine called for 80% of the U.S. nursing workforce to hold a BSN. Magnet hospitals require it. Employers increasingly require it. Beyond credentialing, the BSN builds the research, leadership, and population-health competencies that separate nurses who follow the care plan from nurses who shape it.",
        "image": "https://nursing.maryville.edu/media_19b4a24b43ec640e9af6c0bf3acc5785302c741b8.jpg?width=900&format=jpg&optimize=medium",
        "heading": "<p>Why the BSN Matters Now</p>",
        "imagePosition": "right",
        "backgroundColor": "white",
        "animationVariant": "fadeUp"
      }
    },
    {
